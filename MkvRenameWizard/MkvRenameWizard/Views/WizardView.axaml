<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:MkvRenameWizard.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MkvRenameWizard.Views.WizardView"
             x:DataType="viewModels:WizardViewModel">
    <UserControl.Styles>
        <Style Selector="Button.primary-action">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"></Setter>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"></Setter>
            <Setter Property="FontWeight" Value="SemiBold"></Setter>
            <Setter Property="Padding" Value="18,9"></Setter>
        </Style>
        
        <Style Selector="Button.secondary-action">
            <Setter Property="Background" Value="Transparent"></Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"></Setter>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"></Setter>
            <Setter Property="Padding" Value="14,9"></Setter>
        </Style>
    </UserControl.Styles>
    <Grid>
        <Carousel ItemsSource="{Binding Pages}"
                  SelectedIndex="{Binding CurrentPageIndex}">
            <Carousel.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" />
                </DataTemplate>
            </Carousel.ItemTemplate>
        </Carousel>
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom">
            <Button Content="Previous" 
                    Command="{Binding PreviousCommand}"
                    IsVisible="{Binding CanGoBack}"/>
            <Button Content="Next" 
                    Command="{Binding NextCommand}"
                    IsVisible="{Binding CanGoForward}"/>
            <Button Content="Finish" 
                    Command="{Binding FinishCommand}"
                    IsVisible="{Binding IsLastPage}"/>
        </StackPanel>
    </Grid>
</UserControl>
