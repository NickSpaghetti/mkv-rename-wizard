    <!--         <ItemsControl.ItemTemplate> -->
    <!--             <DataTemplate> -->
    <!--                 <CheckBox Content="{Binding Label}"  -->
    <!--                           IsChecked="{Binding IsChecked}"/> -->
    <!--             </DataTemplate> -->
    <!--         </ItemsControl.ItemTemplate> -->
    <!--     </ItemsControl> -->
    <!-- </Grid> -->
</UserControl>